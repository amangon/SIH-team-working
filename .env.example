# ─────────────────────────────────────────────
# TeamSync AI — Environment Variables
# Copy this file to server/.env and fill values
# ─────────────────────────────────────────────

# ── Server ──
NODE_ENV=development
PORT=5050
CLIENT_URL=http://localhost:5173

# ── Database ──
MONGO_URI=mongodb://127.0.0.1:27017/teamsync-ai

# ── JWT ──
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── File Storage ──
# STORAGE_DRIVER: "local" (default, saves to server/uploads) or "cloudinary"
STORAGE_DRIVER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email ──
# EMAIL_DRIVER: "console" (default, logs emails to terminal) or "smtp"
EMAIL_DRIVER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="TeamSync AI <no-reply@teamsync.ai>"

# ── AI Code Review ──
# AI_DRIVER: "mock" (default, heuristic review) or "anthropic"
AI_DRIVER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Google OAuth (optional) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Redis (optional) ──
REDIS_URL=
